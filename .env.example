# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

APP_AUTH_SECRET=your_local_auth_secret
APP_LOGIN_EMAIL=admin@example.com
APP_LOGIN_PASSWORD=admin123

# AI / Integrations (placeholders only)
OPENAI_API_KEY=your_openai_api_key
GOOGLE_ADS_TOKEN=your_google_ads_token
META_ACCESS_TOKEN=your_meta_access_token
BIGQUERY_PROJECT_ID=your_bigquery_project_id

# Data layer
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mcc
REDIS_URL=redis://localhost:6379/0

# CORS (deployment)
# Include exact frontend origins separated by comma (e.g. Vercel production + preview domains)
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Regex fallback for preview domains (default works for *.vercel.app)
APP_CORS_ORIGIN_REGEX=https://.*\.vercel\.app
