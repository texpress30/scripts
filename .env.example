# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

APP_AUTH_SECRET=your_local_auth_secret
APP_LOGIN_EMAIL=admin@example.com
APP_LOGIN_PASSWORD=admin123

# AI / Integrations (optional for boot; required for full features)
OPENAI_API_KEY=your_openai_api_key
GOOGLE_ADS_TOKEN=your_google_ads_token
META_ACCESS_TOKEN=your_meta_access_token
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_REDIRECT_URI=http://localhost:3000/agency/integrations/meta/callback
META_API_VERSION=v20.0

# Shopify Feed Integration (VOXEL app - OAuth)
# Flow: Add New Source → OAuth redirect → callback → token stored → import products
# Create app at https://partners.shopify.com/ → Apps → VOXEL → Settings for credentials
# Webhook app/uninstalled is auto-registered at OAuth exchange
# Token-urile offline NU expiră; se revocă doar la uninstall (webhook app/uninstalled)
SHOPIFY_APP_CLIENT_ID=
SHOPIFY_APP_CLIENT_SECRET=
SHOPIFY_REDIRECT_URI=https://admin.omarosa.ro/agency/integrations/shopify/callback
SHOPIFY_API_VERSION=2026-04
SHOPIFY_SCOPES=read_products,read_product_listings,read_inventory,read_locations
# Optional: base URL for the webhook callback Shopify should call on app uninstall
# (default https://admin.omarosa.ro; the full path is /api/integrations/shopify/webhooks/app-uninstalled)
SHOPIFY_WEBHOOK_BASE_URL=https://admin.omarosa.ro

# BigCommerce OAuth App (Developer Portal)
# Flow: Merchant installs app → BC redirects to BC_REDIRECT_URI with code →
# server exchanges code → token stored encrypted per store_hash.
# Create app at https://devtools.bigcommerce.com/ → My Apps → Draft Apps
# The three JWT-verified callbacks (load/uninstall/remove_user) share the same
# client_secret — no PyJWT needed, verified with stdlib HS256.
BC_CLIENT_ID=
BC_CLIENT_SECRET=
BC_CLIENT_UUID=
BC_REDIRECT_URI=https://admin.omarosa.ro/agency/integrations/bigcommerce/callback
# Optional: override the default read-only scope list
BC_SCOPES=store_v2_products_read_only store_v2_content_read_only store_v2_information_read_only

BIGQUERY_PROJECT_ID=your_bigquery_project_id

# Data layer
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mcc
REDIS_URL=redis://localhost:6379/0
MONGO_URI=
MONGO_DATABASE=

# Storage foundation (S3)
STORAGE_S3_BUCKET=
STORAGE_S3_REGION=
STORAGE_S3_ENDPOINT_URL=
STORAGE_S3_PRESIGNED_TTL_SECONDS=900
STORAGE_MEDIA_CLEANUP_BATCH_LIMIT=100
STORAGE_MEDIA_REMOTE_FETCH_TIMEOUT_SECONDS=15
STORAGE_MEDIA_REMOTE_FETCH_MAX_BYTES=10485760
STORAGE_MEDIA_SYNC_WORKER_REMOTE_INGEST_ENABLED=false
CREATIVE_WORKFLOW_MONGO_SHADOW_WRITE_ENABLED=false
CREATIVE_WORKFLOW_MONGO_CORE_WRITES_SOURCE_ENABLED=false
CREATIVE_WORKFLOW_MONGO_DERIVED_WRITES_SOURCE_ENABLED=false
CREATIVE_WORKFLOW_MONGO_PUBLISH_PERSIST_ENABLED=false
CREATIVE_WORKFLOW_MONGO_READ_THROUGH_ENABLED=false
CREATIVE_WORKFLOW_MONGO_READS_SOURCE_ENABLED=false
CREATIVE_WORKFLOW_MEDIA_ID_LINKING_ENABLED=false
AI_RECOMMENDATIONS_MONGO_SOURCE_ENABLED=false

# CORS (deployment)
# Include exact frontend origins separated by comma (e.g. Vercel production + preview domains)
APP_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Regex fallback for preview domains (default works for *.vercel.app)
APP_CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Google Ads rolling sync (UI)
GOOGLE_ADS_UI_ROLLING_SYNC_DAYS=7
GOOGLE_ADS_UI_ROLLING_CHUNK_DAYS=7
GOOGLE_ADS_HISTORICAL_BACKFILL_START_DATE=2024-01-09
